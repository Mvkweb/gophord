# Discord Bot Token
# Get from: https://discord.com/developers/applications → Bot → Token
# 1. Create/select your application
# 2. Go to "Bot" section
# 3. Copy the token (click "Reset Token" if needed)
DISCORD_BOT_TOKEN=your_bot_token_here

# Optional: Test Guild ID (for slash command development)
# Right-click your server → "Copy Server ID" (Developer Mode required)
TEST_GUILD_ID=

# Optional: Log Level (DEBUG, INFO, WARN, ERROR)
LOG_LEVEL=INFO

# Premium Button SKU ID (required for premium button commands)
# Get from: Discord Developer Portal → Your App → Monetization → SKUs
# Create and publish a SKU, then copy its ID here
DISCORD_SKU_ID=1427227837835776120
